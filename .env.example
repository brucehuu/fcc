# =============================================================================
# 飞书开放平台应用凭证（敏感信息，请勿提交到 git）
# =============================================================================
# 在飞书开放平台 https://open.feishu.cn/app 创建企业自建应用后获取
# ⚠️  警告：env 文件已在 .gitignore 中忽略，但请勿对外分享本文件内容
# ⚠️  警告：若怀疑泄露，请在飞书开放平台重置 App Secret
LARK_APP_ID=cli_xxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxx

# 飞书账号名（可选）
# 用于配置窗口中的"测试消息"功能，填写后可一键发送测试消息验证配置
# TARGET_NAME=

# =============================================================================
# 终端命令配置
# =============================================================================
# 要桥接的终端命令（直接启动，通过 tmux 交互）
# 可以是 claude、codex、aider 等任何交互式 CLI 工具
# 需要带参数时直接写，如：COMMAND=bash -il
COMMAND=claude

# =============================================================================
# 免确认模式（可选）
# =============================================================================
# 设为 true 时，对应工具会跳过所有权限确认提示
# 注意：此模式会降低安全性，请仅在可信环境下使用
# 支持的工具及对应参数：
#   - claude → --dangerously-skip-permissions
#   - codex  → --dangerously-bypass-approvals-and-sandbox
BYPASS_PERMISSIONS=false

# =============================================================================
# Codex 专属配置（可选）
# =============================================================================
# Codex 默认使用的 follow-up 队列模式
#   guide  - 引导模式：新消息到达时引导用户进入
#   queue  - 排队模式：新消息自动排队
# 仅当 COMMAND=codex 时生效
CODEX_QUEUE_MODE=guide

# =============================================================================
# 性能调优（可选）
# =============================================================================
# 终端屏幕捕获间隔（秒）。值越小越实时，但 CPU 占用越高
# 支持自适应捕获：程序会根据终端活跃程度自动调整间隔
# CAPTURE_INTERVAL=3
# CAPTURE_INTERVAL_MIN=500ms
# CAPTURE_INTERVAL_MAX=60s

# 单条消息发送超时（秒）。超过后会自动重试
# SEND_TIMEOUT=10

# 发送失败重试次数
# SEND_RETRIES=3

# 日志级别（可选）
#   debug   - 调试信息
#   info    - 一般信息（默认）
#   warn    - 警告信息
#   warning - 警告信息（warn 的别名）
#   error   - 错误信息
# LOG_LEVEL=info

# tmux 历史缓冲区行数（应对长输出截断）
# TMUX_HISTORY_LINES=2000

# 噪音过滤关键词列表（逗号分隔，可选）
# 匹配这些关键词的行会被过滤，避免发送无意义的中间状态到飞书
# 默认值：fluttering,nesting,thinking
# NOISE_PATTERNS=fluttering,nesting,thinking

# 进程守护检查间隔（秒），值越小恢复越快但 CPU 占用越高
# WATCHDOG_CHECK_INTERVAL=6

# 中断命令防抖间隔（毫秒），防止短时间内重复发送中断信号
# INTERRUPT_DEBOUNCE=500ms
